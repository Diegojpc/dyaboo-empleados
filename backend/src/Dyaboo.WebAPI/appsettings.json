{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Dyaboo": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer":   "dyaboo-api",
    "Audience": "dyaboo-frontend"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "Minio": {
    "Endpoint":  "localhost:9000",
    "Bucket":    "dyaboo-assets",
    "PublicUrl": "http://localhost:9000",
    "UseSSL":    false
  }
}
