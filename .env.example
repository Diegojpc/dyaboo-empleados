# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=dyaboo_user
POSTGRES_PASSWORD=CAMBIAR_EN_PRODUCCION
POSTGRES_DB=dyaboo_db

# ── MinIO – Object Storage ────────────────────────────────────────────────────
MINIO_ROOT_USER=dyaboo_minio
MINIO_ROOT_PASSWORD=CAMBIAR_EN_PRODUCCION

# ── JWT — OBLIGATORIO — mínimo 32 caracteres, generado aleatoriamente ─────────
# Generar con: openssl rand -base64 48
JWT_SECRET_KEY=CAMBIAR_EN_PRODUCCION_MIN_32_CARACTERES_ALEATORIO
JWT_ISSUER=dyaboo-api
JWT_AUDIENCE=dyaboo-frontend

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_MINIO_URL=http://localhost:9000
